// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js" // Prisma 7 使用 prisma-client-js
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projects  Project[]
}

model Project {
  id            Int           @id @default(autoincrement())
  userId        Int
  title         String
  description   String?
  coverImageUrl String?
  status        ProjectStatus @default(DRAFT)
  progress      Int           @default(0)
  currentStep   Int           @default(1)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  files           ProjectFile[]
  subtitleEntries SubtitleEntry[]

  @@index([userId])
  @@index([status])
}

model SubtitleEntry {
  id          Int      @id @default(autoincrement())
  projectId   Int
  index       Int
  startTime   String
  endTime     String
  original    String
  translation String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, index])
  @@index([projectId])
}

model ProjectFile {
  id           Int      @id @default(autoincrement())
  projectId    Int
  originalName String
  storageKey   String
  fileUrl      String
  mimeType     String?
  extension    String?
  size         Int
  fileType     FileType @default(SUBTITLE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([fileType])
}

enum ProjectStatus {
  DRAFT
  UPLOADING
  PROCESSING
  COMPLETED
  FAILED
}

enum FileType {
  SUBTITLE
  TRANSLATED_SUBTITLE
  OTHER
}
